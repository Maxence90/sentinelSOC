# Chain selection
SELECTED_CHAIN=ethereum

# Ethereum RPC Provider
ETHEREUM_WS_URL=
ETHEREUM_HTTP_URL=
INFURA_WS_URL=wss://mainnet.infura.io/ws/v3/YOUR_INFURA_KEY
INFURA_HTTP_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY

# Alternative: Alchemy
ALCHEMY_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# 0G RPC Provider
OG_WS_URL=
OG_HTTP_URL=

# Monad RPC Provider
MONAD_WS_URL=
MONAD_HTTP_URL=

# Optional runtime overrides
ETHEREUM_ANALYSIS_TIMEOUT_MS=
ETHEREUM_MAX_QUEUE_SIZE=
ETHEREUM_WORKER_COUNT=
OG_ANALYSIS_TIMEOUT_MS=
OG_MAX_QUEUE_SIZE=
OG_WORKER_COUNT=
MONAD_ANALYSIS_TIMEOUT_MS=
MONAD_MAX_QUEUE_SIZE=
MONAD_WORKER_COUNT=

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sentinelsoc

# Notifications
FEISHU_WEBHOOK_URL=
FEISHU_ALERT_MIN_SCORE=30

# Logging
LOG_LEVEL=debug
